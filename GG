<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal de Resultados | Global System</title>
    <style>
        /* Eliminamos margenes y obligamos a que ocupe toda la pantalla */
        body, html { margin: 0; padding: 0; height: 100%; width: 100%; overflow: hidden; background-color: #f8fafc; }
        
        .contenedor-oculto {
            position: absolute;
            top: -50px; /* Este es el truco: sube la página 50px para dejar el banner fuera */
            left: 0;
            width: 100%;
            height: calc(100% + 50px);
        }
        
        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
</head>
<body>
    <div class="contenedor-oculto">
        <iframe src="https://script.google.com/macros/s/AKfycbzoLIck66nX87RhOLX_stfjHz2sTG3msv6n_8LXq4KWrPGUshgLgxakiC4-x-LC4KDe/exec"></iframe>
    </div>
</body>
</html>
